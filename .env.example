# Email de la Service Account habilitada para Earth Engine
GEE_SERVICE_ACCOUNT_EMAIL=my-sa@my-project.iam.gserviceaccount.com

# Clave privada de la Service Account. Pegar el JSON completo en UNA sola línea
# (reemplazar los saltos de línea de "private_key" por \n) o en base64.
# Ejemplo (JSON en una línea):
# GEE_PRIVATE_KEY_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n", ...}
GEE_PRIVATE_KEY_JSON=

# Alternativa: mismo JSON pero codificado en base64 (recomendado en Vercel)
# GEE_PRIVATE_KEY_JSON_B64=
